    {
      "id": "el_0059",
      "type": "text",
      "x": 480,
      "y": 1020,
      "width": 520,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
