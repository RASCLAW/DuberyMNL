# DuberyMNL Command Center -- required env vars (real values in project .env)

# Flask
COMMAND_CENTER_PORT=8090

# Claude Agent SDK auth. Leave ANTHROPIC_API_KEY unset to use Claude Code
# subscription auth inherited from the logged-in Claude CLI.
# ANTHROPIC_API_KEY=sk-ant-...

# Monitor: Meta Ads
META_PAGE_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Monitor: Cloudflare Worker fallback (leave blank -> monitor reports not_wired)
WORKER_URL=

# Monitor: GitHub Actions (story rotation)
GITHUB_TOKEN=
GITHUB_OWNER=

# Monitor: Telegram bots
TELEGRAM_BOT_TOKEN=
RASCLAW_BOT_TOKEN=

# Monitor: CRM Google Sheet (existing vars, same as chatbot)
GOOGLE_SHEETS_SPREADSHEET_ID=
